# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=ideavault

# --- Auth ---
# Use a long random string. Must match nothing else; keep it secret.
JWT_SECRET=change-me-to-a-long-random-secret

# --- CORS / frontend ---
# The Next.js client origin(s) allowed to call this API with credentials.
# Comma-separate multiple origins.
CLIENT_ORIGIN=http://localhost:3000
# Where OAuth flows redirect the browser back to after login.
FRONTEND_URL=http://localhost:3000

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL of THIS backend (used to build the OAuth redirect_uri).
SERVER_URL=http://localhost:5000
